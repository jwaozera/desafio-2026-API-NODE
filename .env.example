# porta do servidor
PORTA=3000

# url de conexão com o postgresql (docker-compose padrão)
DATABASE_URL="postgresql://docker:docker_password@localhost:5432/species_api?schema=public"

# segredo para assinar tokens jwt (trocar em produção)
JWT_SECRETO="trocar_por_um_segredo_forte_em_producao"

# tempo de expiração do token jwt
JWT_EXPIRACAO="24h"
